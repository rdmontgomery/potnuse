  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.0",
    "happy-dom": "^15.0.0",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5.6.0",
    "vite": "^7",
    "zod": "^3 || ^4",
    "zustand": "^5"
  }
