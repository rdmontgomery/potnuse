---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  title = 'potnuse',
  description,
  image = '/og-default.png',
  type,
} = Astro.props;

const SITE = 'https://rdmontgomery.com';
const canonical = new URL(Astro.url.pathname, SITE).toString();
const ogImage = new URL(image, SITE).toString();
const ogType = type ?? (Astro.url.pathname === '/' ? 'website' : 'article');
const ogDesc =
  description ?? 'a garden with the workshop door left ajar';
const displayTitle =
  title === 'potnuse' ? 'rdmontgomery.com' : `${title} — rdmontgomery.com`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>

    <meta property="og:site_name" content="rdmontgomery.com" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={displayTitle} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={displayTitle} />
    <meta name="twitter:description" content={ogDesc} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400..900;1,400..900&family=JetBrains+Mono:wght@300..800&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=STIX+Two+Text:ital,wght@0,400;0,500;1,400&display=swap"
    />
  </head>
  <body>
    <slot />

    <script>
      // Up Up Down Down Left Right Left Right — opens /rhizome from anywhere.
      // Two input paths: keyboard (desktop) and a single continuous finger
      // drag (mobile) that traces the same directions.

      /** @type {Array<'U'|'D'|'L'|'R'>} */
      const SEQUENCE = ['U', 'U', 'D', 'D', 'L', 'R', 'L', 'R'];
      const KEY_TO_DIR = {
        ArrowUp: 'U',
        ArrowDown: 'D',
        ArrowLeft: 'L',
        ArrowRight: 'R',
      };

      function enter() {
        window.location.href = '/rhizome';
      }

      // --- keyboard ---
      let keyPos = 0;
      window.addEventListener('keydown', (ev) => {
        const target = ev.target;
        if (
          target instanceof HTMLElement &&
          (target.isContentEditable ||
            target.tagName === 'INPUT' ||
            target.tagName === 'TEXTAREA')
        ) {
          return;
        }
        const dir = KEY_TO_DIR[ev.key];
        if (!dir) {
          keyPos = 0;
          return;
        }
        keyPos =
          dir === SEQUENCE[keyPos]
            ? keyPos + 1
            : dir === SEQUENCE[0]
              ? 1
              : 0;
        if (keyPos === SEQUENCE.length) {
          keyPos = 0;
          enter();
        }
      });

      // --- touch: one continuous drag tracing the sequence ---
      // Segment the path whenever direction changes past a minimum leg.
      // MIN_LEG filters jitter; only past the 2nd matching leg do we
      // preventDefault so ordinary scroll gestures still work.
      const MIN_LEG = 28; // px in the dominant axis before we count a leg
      /** @type {Array<'U'|'D'|'L'|'R'>} */
      let legs = [];
      let lastX = 0;
      let lastY = 0;
      let anchorX = 0;
      let anchorY = 0;
      let tracking = false;
      let currentDir = null;

      function matchesSoFar() {
        if (legs.length > SEQUENCE.length) return false;
        for (let i = 0; i < legs.length; i++) {
          if (legs[i] !== SEQUENCE[i]) return false;
        }
        return true;
      }

      window.addEventListener(
        'touchstart',
        (ev) => {
          if (ev.touches.length !== 1) {
            tracking = false;
            legs = [];
            return;
          }
          const t = ev.touches[0];
          tracking = true;
          legs = [];
          currentDir = null;
          lastX = anchorX = t.clientX;
          lastY = anchorY = t.clientY;
        },
        { passive: true },
      );

      window.addEventListener(
        'touchmove',
        (ev) => {
          if (!tracking || ev.touches.length !== 1) return;
          const t = ev.touches[0];
          lastX = t.clientX;
          lastY = t.clientY;
          const dx = lastX - anchorX;
          const dy = lastY - anchorY;
          const adx = Math.abs(dx);
          const ady = Math.abs(dy);
          const dominant = adx > ady ? adx : ady;
          if (dominant < MIN_LEG) return;

          const dir =
            adx > ady ? (dx > 0 ? 'R' : 'L') : dy > 0 ? 'D' : 'U';

          if (dir !== currentDir) {
            legs.push(dir);
            currentDir = dir;
            if (!matchesSoFar()) {
              // failed — stop tracking this gesture, let the page scroll.
              tracking = false;
              legs = [];
              return;
            }
          }
          // reset anchor so the next leg is measured from the pivot point
          anchorX = lastX;
          anchorY = lastY;

          // once we're clearly in the combo, suppress scroll so the
          // remaining legs can be traced without the page moving.
          if (legs.length >= 2 && ev.cancelable) {
            ev.preventDefault();
          }
        },
        { passive: false },
      );

      window.addEventListener('touchend', () => {
        if (tracking && legs.length === SEQUENCE.length && matchesSoFar()) {
          legs = [];
          tracking = false;
          enter();
          return;
        }
        tracking = false;
        legs = [];
      });

      window.addEventListener('touchcancel', () => {
        tracking = false;
        legs = [];
      });
    </script>

    <style is:global>
      :root {
        --font-crimson: 'Crimson Pro', Georgia, 'Iowan Old Style', serif;
        --font-jetbrains: 'JetBrains Mono', ui-monospace, 'SF Mono', monospace;
        --bg: #1a1207;
        --bg-card: #261d0f;
        --bg-button: #332814;
        --accent: #e8a838;
        --accent-dim: #b87a1e;
        --text: #f0e6d2;
        --text-dim: #9e8e72;
        --text-muted: #6b5d48;
        --border: #3d2e1a;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-crimson);
        font-size: 18px;
        line-height: 1.55;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      ::selection {
        background: var(--accent);
        color: var(--bg);
      }
    </style>
  </body>
</html>
