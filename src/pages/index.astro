---
import Base from '@/layouts/Base.astro';
import { buildGraph } from '@/lib/graph';

// Graph baked into the page at build so the click doesn't need a fetch.
const graph = await buildGraph();
---

<Base title="potnuse">
  <main class="door">
    <button class="sigil" type="button" aria-label="enter">
      <svg viewBox="0 0 120 120" width="140" height="140" aria-hidden="true">
        <circle
          cx="60"
          cy="60"
          r="52"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
          stroke-dasharray="3 6"
        />
        <circle
          cx="60"
          cy="60"
          r="34"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
          stroke-dasharray="2 5"
        />
        <circle
          cx="60"
          cy="60"
          r="16"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
        />
        <circle cx="60" cy="60" r="3" fill="currentColor" />
      </svg>
    </button>
  </main>
</Base>

<script define:vars={{ graph }}>
  const button = document.querySelector('.sigil');
  if (button && Array.isArray(graph) && graph.length > 0) {
    button.addEventListener('click', () => {
      const node = graph[Math.floor(Math.random() * graph.length)];
      if (node && node.url) {
        window.location.href = node.url;
      }
    });
  }
</script>

<style>
  .door {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
  }
  .sigil {
    background: none;
    border: none;
    color: var(--text);
    cursor: pointer;
    padding: 1.5rem;
    opacity: 0.75;
    transition:
      opacity 0.8s ease,
      color 0.6s ease,
      transform 1.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .sigil:hover,
  .sigil:focus-visible {
    opacity: 1;
    color: var(--accent);
    transform: rotate(18deg);
    outline: none;
  }
  .sigil:active {
    transform: rotate(32deg) scale(0.96);
    transition-duration: 0.2s;
  }
</style>
