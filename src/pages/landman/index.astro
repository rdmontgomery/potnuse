---
import Landman from '@/layouts/Landman.astro';

const project = {
  name: 'Caldwell Parish Mineral Study',
  client: 'Cypress Energy Partners',
  jurisdiction: 'Caldwell Parish, Louisiana',
  aoi: '640.3 acres · Section 14, T-11-N, R-3-E',
  rights: 'Mineral',
};

interface StepSpec {
  id: string;
  name: string;
  ms: number;
  detail: string;
  running?: string[]; // rotating status lines while running
  before: string; // "a landman would…"
}

const steps: StepSpec[] = [
  {
    id: 'aoi',
    name: 'AOI ingest',
    ms: 140,
    detail: 'KMZ parsed · 640.3 acres · EPSG:4326',
    before: 'Open the KMZ, take a screenshot, print it.',
  },
  {
    id: 'parcels',
    name: 'Parcel intersect',
    ms: 280,
    detail: '4 parcels matched within AOI',
    before: 'Cross-reference the plat book by hand.',
  },
  {
    id: 'tax',
    name: 'Tax record pull',
    ms: 620,
    detail: '4/4 assessment records · assessed owners resolved',
    before: 'Call the assessor or walk into the parish office.',
  },
  {
    id: 'routing',
    name: 'Jurisdiction routing',
    ms: 60,
    detail: 'Caldwell Parish Clerk of Court · conveyance + mortgage books',
    before: 'Know the parish. If you don\'t, ask another landman.',
  },
  {
    id: 'search',
    name: 'Index search',
    ms: 2400,
    detail: '47 candidate instruments identified',
    running: [
      'searching conveyance book 1870–1900…',
      'searching conveyance book 1900–1930…',
      'searching conveyance book 1930–1960…',
      'searching conveyance book 1960–present…',
      'cross-referencing mortgage book…',
    ],
    before: 'Days at the courthouse, grantor-grantee bounce.',
  },
  {
    id: 'ocr',
    name: 'OCR + extract',
    ms: 3800,
    detail: '8 instruments logged · 6 parties · 2 tracts',
    running: [
      'reading US Patent (1878)…',
      'reading Warranty Deed (1901)…',
      'reading Succession of Thomasson (1934)…',
      'reading Warranty Deed (1962)…',
      'reading Mineral Deed + reservation (1987)…',
      'reading Mineral Deed, partial (2015)…',
      'reading OGL (2017)…',
      'reconciling party name variants…',
    ],
    before: 'Transcribe every deed by hand, abstract the terms.',
  },
  {
    id: 'chain',
    name: 'Chain assembly',
    ms: 180,
    detail: '2 tracts · 8-instrument chain · 1 gap flagged',
    before: 'Draw it on a legal pad. Erase. Redraw.',
  },
  {
    id: 'interest',
    name: 'Interest arithmetic',
    ms: 40,
    detail: '6 owners · fractions balanced · NPRI tracked',
    before: 'Recompute fractions every time a deed reserves something.',
  },
  {
    id: 'exceptions',
    name: 'Exception cataloging',
    ms: 80,
    detail: '3 exceptions · 0 blocking · 1 curative recommended',
    before: 'Flag them in a spreadsheet. Hope you didn\'t miss one.',
  },
  {
    id: 'deliver',
    name: 'Deliverables',
    ms: 1200,
    detail: 'run sheet · chain flowchart · interest table · draft opinion',
    before: 'Three days of formatting in Word.',
  },
];

const totalMs = steps.reduce((s, x) => s + x.ms, 0);

// Run sheet instruments
const instruments = [
  { date: '1878-04-12', type: 'US Patent', grantor: 'United States', grantee: 'William T. Johnson', ref: 'Patent 4021', tract: 'T1' },
  { date: '1901-09-03', type: 'Warranty Deed', grantor: 'William T. Johnson', grantee: 'James Thomasson', ref: 'CB 47 p. 219', tract: 'T1' },
  { date: '1934-06-18', type: 'Succession', grantor: 'Estate of James Thomasson', grantee: 'Thomasson heirs (multiple)', ref: 'Docket 44-338', tract: 'T1, T2' },
  { date: '1962-11-22', type: 'Warranty Deed', grantor: 'Thomasson heirs', grantee: 'Beatrice Johnson', ref: 'CB 214 p. 77', tract: 'T1' },
  { date: '1987-03-08', type: 'Mineral Deed (w/ reservation)', grantor: 'Beatrice Johnson', grantee: 'W.T. Johnson, Jr.', ref: 'CB 514 p. 401', tract: 'T1' },
  { date: '2015-08-14', type: 'Mineral Deed (partial)', grantor: 'W.T. Johnson, Jr.', grantee: 'Thomasson Heirs, LLC', ref: 'CB 801 p. 55', tract: 'T1, T2' },
  { date: '2017-03-14', type: 'Oil & Gas Lease', grantor: 'W.T. Johnson, Jr.', grantee: 'Delta Exploration LLC', ref: 'CB 842 p. 113', tract: 'T1' },
  { date: '2017-04-02', type: 'Oil & Gas Lease', grantor: 'Thomasson Heirs, LLC', grantee: 'Delta Exploration LLC', ref: 'CB 842 p. 178', tract: 'T2' },
];

const interests = [
  { party: 'W.T. Johnson, Jr.', type: 'Mineral', fraction: '1/2', note: 'leased to Delta Exploration (2017)' },
  { party: 'Thomasson Heirs, LLC', type: 'Mineral', fraction: '1/2', note: 'leased to Delta Exploration (2017)' },
  { party: 'Estate of James Thomasson', type: 'NPRI', fraction: '1/32', note: 'carved out in 1987 deed, runs with mineral estate' },
  { party: 'Delta Exploration LLC', type: 'Working Interest', fraction: '100% leasehold', note: 'both halves leased; HBP' },
];

const exceptions = [
  {
    severity: 'noted',
    title: 'Outstanding oil & gas lease',
    detail: 'Delta Exploration LLC, dated 2017-03-14 & 2017-04-02. Primary term 3 years, held by production. Lessor: W.T. Johnson Jr. and Thomasson Heirs, LLC respectively.',
  },
  {
    severity: 'noted',
    title: '1/32 NPRI reservation',
    detail: 'Reserved in 1987 Mineral Deed (CB 514 p. 401) in favor of Estate of James Thomasson. Runs with the mineral estate and burdens all lessees.',
  },
  {
    severity: 'curable',
    title: 'Recording gap, 1923–1934 (Tract 1, Tract 2)',
    detail: 'James Thomasson died 1923; succession not opened until 1934. Heirs identified by the 1934 succession filing. Curative: affidavit of heirship recommended to clean the 11-year gap.',
  },
];

// Chain of title for Tract 1 — used in the SVG flowchart
const chain = [
  { year: 1878, type: 'US Patent', label: 'USA → W.T. Johnson' },
  { year: 1901, type: 'Warranty Deed', label: 'W.T. Johnson → J. Thomasson' },
  { year: 1934, type: 'Succession', label: 'Est. Thomasson → heirs', gapBefore: true, gapNote: '1923 death, 1934 filing' },
  { year: 1962, type: 'Warranty Deed', label: 'Heirs → B. Johnson' },
  { year: 1987, type: 'Mineral Deed', label: 'B. Johnson → W.T. Jr. (reserves 1/32 NPRI)' },
  { year: 2015, type: 'Mineral Deed', label: 'W.T. Jr. → Thomasson Heirs LLC (1/2)' },
  { year: 2017, type: 'OGL', label: 'W.T. Jr. → Delta Expl. (HBP)' },
];
---

<Landman title="pipeline demo">
  <p class="kicker">internal · title-pipeline demo · v0</p>
  <h1>Title research runs itself.</h1>
  <p class="deck">
    A real landman project — KMZ in, title opinion out. What used to be two to
    three weeks of courthouse work is now a pipeline you watch in a coffee
    break. Push the button.
  </p>

  <!-- ============ Interactive pipeline widget ============ -->
  <section class="pipeline" id="pipeline">
    <div class="pipeline-head">
      <div class="project">
        <h3>{project.name}</h3>
        <p>
          <span>{project.client}</span>
          <span>·</span>
          <span>{project.jurisdiction}</span>
          <span>·</span>
          <span>{project.aoi}</span>
          <span>·</span>
          <span>rights: {project.rights}</span>
        </p>
      </div>
      <button id="run-btn" class="run-btn" data-state="idle">
        <span class="label-idle">▸ Run pipeline</span>
        <span class="label-running">running…</span>
        <span class="label-done">▸ Run again</span>
      </button>
    </div>

    <ol class="steps" id="steps">
      {steps.map((s, i) => (
        <li data-step={s.id} data-index={i}>
          <span class="glyph">○</span>
          <span class="name">{s.name}</span>
          <span class="detail"></span>
          <span class="time"></span>
        </li>
      ))}
    </ol>

    <div class="summary" id="summary" hidden>
      <div class="summary-total">
        <span class="k">pipeline total</span>
        <strong id="total-time">—</strong>
      </div>
      <div class="summary-compare">
        <span class="k">landman equivalent</span>
        <strong>~80 h</strong>
        <span class="delta">≈ 15,000× faster</span>
      </div>
      <div class="summary-quick">
        <a href="#run-sheet">run sheet</a>
        <a href="#chain">chain of title</a>
        <a href="#interests">interests</a>
        <a href="#exceptions">exceptions</a>
        <a href="#opinion">draft opinion</a>
      </div>
    </div>
  </section>

  <!-- ============ What just happened ============ -->
  <h2>What just happened.</h2>
  <p class="deck-sub">
    Ten steps. Each one used to be a human with a phone, a pen, or a drive to
    the parish office.
  </p>

  <ol class="narrative">
    {steps.map((s, i) => (
      <li>
        <div class="n-head">
          <span class="n-num">{String(i + 1).padStart(2, '0')}</span>
          <h3>{s.name}</h3>
        </div>
        <p class="n-before"><em>before:</em> {s.before}</p>
        <p class="n-after"><em>now:</em> {s.detail}</p>
      </li>
    ))}
  </ol>

  <!-- ============ Deliverables ============ -->
  <h2 id="deliverables">Deliverables.</h2>
  <p class="deck-sub">
    Four artifacts, generated. A human reviews and signs; a human does not
    produce.
  </p>

  <!-- Run sheet -->
  <section id="run-sheet" class="deliver">
    <h3>Run sheet</h3>
    <p class="dsub">Every instrument affecting the chain, chronologically.</p>
    <table class="lm">
      <thead>
        <tr>
          <th>date</th>
          <th>type</th>
          <th>grantor</th>
          <th>grantee</th>
          <th>recording</th>
          <th>tract</th>
        </tr>
      </thead>
      <tbody>
        {instruments.map((x) => (
          <tr>
            <td class="mono">{x.date}</td>
            <td>{x.type}</td>
            <td>{x.grantor}</td>
            <td>{x.grantee}</td>
            <td class="mono">{x.ref}</td>
            <td class="mono">{x.tract}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <!-- Chain of title -->
  <section id="chain" class="deliver">
    <h3>Chain of title · Tract 1</h3>
    <p class="dsub">Sovereign forward. One gap flagged.</p>
    <div class="chain-wrap">
      <svg class="chain-svg" viewBox="0 0 520 660" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="chain of title for Tract 1">
        <defs>
          <marker id="arr" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,0 L10,5 L0,10 z" fill="#807c72" />
          </marker>
          <marker id="arr-gap" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,0 L10,5 L0,10 z" fill="#c96b5a" />
          </marker>
        </defs>
        {chain.map((c, i) => {
          const y = 20 + i * 90;
          return (
            <g>
              {i > 0 && !c.gapBefore && (
                <line x1="260" y1={y - 70} x2="260" y2={y - 2} stroke="#807c72" stroke-width="1.2" marker-end="url(#arr)" />
              )}
              {c.gapBefore && (
                <>
                  <line x1="260" y1={y - 70} x2="260" y2={y - 2} stroke="#c96b5a" stroke-width="1.2" stroke-dasharray="4 4" marker-end="url(#arr-gap)" />
                  <text x="270" y={y - 34} fill="#c96b5a" font-size="11" font-family="JetBrains Mono, ui-monospace, monospace">GAP · {c.gapNote}</text>
                </>
              )}
              <rect x="60" y={y} width="400" height="60" rx="4" fill="#1b1b19" stroke="#2a2a27" />
              <text x="72" y={y + 22} fill="#d49a4a" font-size="11" font-family="JetBrains Mono, ui-monospace, monospace" letter-spacing="1">{c.year} · {c.type}</text>
              <text x="72" y={y + 46} fill="#f3f0e8" font-size="14" font-family="Crimson Pro, Georgia, serif">{c.label}</text>
            </g>
          );
        })}
      </svg>
    </div>
  </section>

  <!-- Interests -->
  <section id="interests" class="deliver">
    <h3>Interest table</h3>
    <p class="dsub">Current ownership. Fractions balance.</p>
    <table class="lm">
      <thead>
        <tr>
          <th>party</th>
          <th>type</th>
          <th>fraction</th>
          <th>note</th>
        </tr>
      </thead>
      <tbody>
        {interests.map((x) => (
          <tr>
            <td>{x.party}</td>
            <td class="mono">{x.type}</td>
            <td class="mono num">{x.fraction}</td>
            <td class="muted">{x.note}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="check">
      <span>✓ Mineral estate: 1/2 + 1/2 = 1 (balanced)</span>
      <span>✓ NPRI burden: 1/32 (disclosed)</span>
      <span>✓ All working interest leased (HBP)</span>
    </p>
  </section>

  <!-- Exceptions -->
  <section id="exceptions" class="deliver">
    <h3>Exceptions</h3>
    <p class="dsub">What the client needs to know about.</p>
    <ul class="exc">
      {exceptions.map((e) => (
        <li data-severity={e.severity}>
          <div class="exc-head">
            <span class={`chip chip-${e.severity}`}>{e.severity}</span>
            <strong>{e.title}</strong>
          </div>
          <p>{e.detail}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- Draft opinion -->
  <section id="opinion" class="deliver">
    <h3>Draft title opinion</h3>
    <p class="dsub">Generated. Review, revise, sign.</p>
    <article class="opinion">
      <header>
        <p class="op-kicker">DRAFT — for attorney review</p>
        <p class="op-to">
          <strong>To:</strong> Cypress Energy Partners<br />
          <strong>Re:</strong> Caldwell Parish Mineral Study · Section 14, T-11-N, R-3-E
        </p>
      </header>

      <h4>I. Conclusion</h4>
      <p>
        Based upon examination of the public records of Caldwell Parish,
        Louisiana, from sovereignty forward, we are of the opinion that
        <strong>marketable title to the mineral estate</strong> in the subject
        property is vested as follows, subject to the exceptions noted in Part
        III below:
      </p>

      <h4>II. Vested ownership</h4>
      <ul>
        <li><strong>W.T. Johnson, Jr.</strong> — an undivided one-half (½) mineral interest</li>
        <li><strong>Thomasson Heirs, LLC</strong> — an undivided one-half (½) mineral interest</li>
        <li>Both interests are burdened by a <strong>one thirty-second (1/32) Non-Participating Royalty Interest</strong> in favor of the Estate of James Thomasson</li>
      </ul>

      <h4>III. Exceptions</h4>
      <ol>
        <li>
          Oil and gas leases in favor of <strong>Delta Exploration LLC</strong>
          dated March 14, 2017 (CB 842 p. 113) and April 2, 2017 (CB 842 p. 178),
          each held by production.
        </li>
        <li>
          One thirty-second (1/32) NPRI reservation in favor of the Estate of
          James Thomasson, created by Mineral Deed dated March 8, 1987 (CB 514 p. 401).
        </li>
        <li>
          <strong>Curative recommendation:</strong> Record an Affidavit of
          Heirship to clean the 1923–1934 recording gap arising from the
          intestate succession of James Thomasson.
        </li>
      </ol>

      <footer>
        <p class="op-sig">
          <span>___________________________</span><br />
          <em>(signature block — attorney of record)</em>
        </p>
      </footer>
    </article>
  </section>

  <!-- Residual -->
  <h2>What's left for the human.</h2>
  <p>
    Not nothing. The pipeline handles the mechanical 90%: ingest, retrieval,
    OCR, chain assembly, arithmetic, formatting. What it doesn't do — what
    Stevie still does, and should — is the judgment work.
  </p>
  <ul class="residual">
    <li><strong>Curative.</strong> The 1923–1934 gap on Tract 1 needs an affidavit of heirship. Drafting it, finding the descendants, getting signatures — human work.</li>
    <li><strong>Ambiguous instruments.</strong> A mineral deed with non-standard reservation language, an old succession with unclear party identity — the model flags it, the human resolves it.</li>
    <li><strong>Client conversation.</strong> "Do you want to proceed despite the NPRI exception?" is not a software question.</li>
    <li><strong>Sign-off.</strong> No opinion leaves without an attorney signature. The pipeline drafts; the attorney signs.</li>
  </ul>
  <p>
    The software does the pipeline work. The landman does the landman work.
    The ratio of those two, right now, is maybe 90-to-10 in the wrong direction.
    This flips it.
  </p>

  <!-- ============ Pipeline runtime ============ -->
  <script define:vars={{ steps, totalMs }}>
    (function () {
      const btn = document.getElementById('run-btn');
      const summary = document.getElementById('summary');
      const totalEl = document.getElementById('total-time');
      const stepEls = Array.from(document.querySelectorAll('#steps [data-step]'));
      let running = false;
      let timers = [];

      const fmt = (ms) => {
        if (ms < 1000) return `${ms} ms`;
        return `${(ms / 1000).toFixed(2)} s`;
      };

      const reset = () => {
        stepEls.forEach((el) => {
          el.classList.remove('is-running', 'is-done');
          el.querySelector('.glyph').textContent = '○';
          el.querySelector('.detail').textContent = '';
          el.querySelector('.time').textContent = '';
        });
        summary.hidden = true;
        btn.dataset.state = 'idle';
      };

      const run = () => {
        if (running) return;
        running = true;
        timers.forEach(clearTimeout);
        timers = [];
        reset();
        btn.dataset.state = 'running';

        let acc = 0;
        steps.forEach((s, i) => {
          const el = stepEls[i];
          const startAt = acc;
          const endAt = acc + s.ms;

          timers.push(setTimeout(() => {
            el.classList.add('is-running');
            el.querySelector('.glyph').textContent = '●';
            if (s.running && s.running.length) {
              let r = 0;
              const cycle = () => {
                if (!el.classList.contains('is-running')) return;
                el.querySelector('.detail').textContent = s.running[r % s.running.length];
                r++;
                timers.push(setTimeout(cycle, Math.max(300, s.ms / (s.running.length + 1))));
              };
              cycle();
            } else {
              el.querySelector('.detail').textContent = '…';
            }
          }, startAt));

          timers.push(setTimeout(() => {
            el.classList.remove('is-running');
            el.classList.add('is-done');
            el.querySelector('.glyph').textContent = '✓';
            el.querySelector('.detail').textContent = s.detail;
            el.querySelector('.time').textContent = fmt(s.ms);
          }, endAt));

          acc = endAt;
        });

        timers.push(setTimeout(() => {
          totalEl.textContent = fmt(totalMs);
          summary.hidden = false;
          btn.dataset.state = 'done';
          running = false;
        }, acc + 120));
      };

      btn.addEventListener('click', run);
    })();
  </script>

  <style>
    .deck-sub {
      color: var(--lm-dim);
      font-size: 1.05rem;
      margin: 0 0 1.4rem;
      max-width: 58ch;
    }

    /* ---------- pipeline widget ---------- */
    .pipeline {
      background: var(--lm-bg-2);
      border: 1px solid var(--lm-border);
      border-radius: 6px;
      padding: 1.6rem 1.6rem 1.8rem;
      margin: 0 0 3rem;
    }
    .pipeline-head {
      display: flex;
      gap: 1.4rem;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      margin-bottom: 1.4rem;
    }
    .project h3 {
      margin: 0 0 0.3rem;
      font-size: 1.2rem;
      font-weight: 500;
    }
    .project p {
      margin: 0;
      font-family: var(--lm-mono);
      font-size: 0.78rem;
      color: var(--lm-muted);
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .run-btn {
      all: unset;
      cursor: pointer;
      background: var(--lm-accent);
      color: #1a1208;
      padding: 0.7rem 1.4rem;
      border-radius: 3px;
      font-family: var(--lm-mono);
      font-weight: 600;
      font-size: 0.88rem;
      letter-spacing: 0.02em;
      transition: background 0.15s, transform 0.05s;
    }
    .run-btn:hover {
      background: #e9ae5c;
    }
    .run-btn:active {
      transform: translateY(1px);
    }
    .run-btn .label-idle,
    .run-btn .label-running,
    .run-btn .label-done { display: none; }
    .run-btn[data-state="idle"] .label-idle { display: inline; }
    .run-btn[data-state="running"] .label-running { display: inline; }
    .run-btn[data-state="running"] {
      background: var(--lm-muted);
      color: var(--lm-bg);
      cursor: wait;
    }
    .run-btn[data-state="done"] .label-done { display: inline; }

    .steps {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.2rem;
    }
    .steps li {
      display: grid;
      grid-template-columns: 1.4rem 11rem 1fr 5rem;
      align-items: baseline;
      gap: 0.8rem;
      padding: 0.45rem 0.6rem;
      border-radius: 3px;
      font-family: var(--lm-mono);
      font-size: 0.82rem;
      color: var(--lm-muted);
      transition: background 0.15s, color 0.15s;
    }
    .steps li .glyph {
      text-align: center;
      color: var(--lm-muted);
    }
    .steps li .name {
      color: var(--lm-dim);
    }
    .steps li .detail {
      color: var(--lm-muted);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .steps li .time {
      text-align: right;
      color: var(--lm-muted);
      font-variant-numeric: tabular-nums;
    }
    .steps li.is-running {
      background: rgba(212, 154, 74, 0.08);
    }
    .steps li.is-running .glyph {
      color: var(--lm-accent);
      animation: pulse 0.8s ease-in-out infinite;
    }
    .steps li.is-running .name,
    .steps li.is-running .detail {
      color: var(--lm-text);
    }
    .steps li.is-done .glyph {
      color: var(--lm-ok);
    }
    .steps li.is-done .name {
      color: var(--lm-text);
    }
    .steps li.is-done .detail,
    .steps li.is-done .time {
      color: var(--lm-dim);
    }
    @keyframes pulse {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }

    .summary {
      margin-top: 1.6rem;
      padding-top: 1.2rem;
      border-top: 1px solid var(--lm-border);
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      align-items: center;
    }
    .summary .k {
      display: block;
      font-family: var(--lm-mono);
      font-size: 0.68rem;
      text-transform: lowercase;
      letter-spacing: 0.1em;
      color: var(--lm-muted);
      margin-bottom: 0.15rem;
    }
    .summary strong {
      font-family: var(--lm-serif);
      font-size: 1.8rem;
      font-weight: 500;
      color: var(--lm-text);
    }
    .summary-compare strong {
      color: var(--lm-dim);
    }
    .summary .delta {
      display: inline-block;
      margin-left: 0.6rem;
      font-family: var(--lm-mono);
      font-size: 0.78rem;
      color: var(--lm-accent);
    }
    .summary-quick {
      margin-left: auto;
      display: flex;
      gap: 1rem;
      font-family: var(--lm-mono);
      font-size: 0.78rem;
      flex-wrap: wrap;
    }
    .summary-quick a {
      color: var(--lm-dim);
      text-decoration: none;
      border-bottom: 1px solid var(--lm-border);
      padding-bottom: 0.1rem;
    }
    .summary-quick a:hover {
      color: var(--lm-accent);
      border-bottom-color: var(--lm-accent);
    }

    /* ---------- narrative ---------- */
    .narrative {
      list-style: none;
      padding: 0;
      margin: 0 0 3rem;
      display: grid;
      gap: 0.9rem;
    }
    .narrative li {
      background: var(--lm-bg-2);
      border: 1px solid var(--lm-border);
      border-left: 3px solid var(--lm-accent-soft);
      border-radius: 3px;
      padding: 0.9rem 1.2rem 1rem;
    }
    .narrative .n-head {
      display: flex;
      align-items: baseline;
      gap: 0.8rem;
      margin-bottom: 0.35rem;
    }
    .narrative .n-num {
      font-family: var(--lm-mono);
      color: var(--lm-muted);
      font-size: 0.76rem;
    }
    .narrative h3 {
      margin: 0;
      font-size: 1.08rem;
      font-weight: 500;
    }
    .narrative .n-before,
    .narrative .n-after {
      margin: 0.1rem 0;
      font-size: 0.95rem;
    }
    .narrative .n-before {
      color: var(--lm-muted);
    }
    .narrative .n-before em,
    .narrative .n-after em {
      font-style: normal;
      font-family: var(--lm-mono);
      font-size: 0.7rem;
      text-transform: lowercase;
      letter-spacing: 0.08em;
      color: var(--lm-muted);
      margin-right: 0.4rem;
    }
    .narrative .n-after {
      color: var(--lm-text);
    }
    .narrative .n-after em {
      color: var(--lm-accent);
    }

    /* ---------- deliverables ---------- */
    .deliver {
      scroll-margin-top: 1rem;
      margin: 2rem 0 2.6rem;
    }
    .deliver h3 {
      margin: 0.6rem 0 0.2rem;
    }
    .deliver .dsub {
      color: var(--lm-muted);
      font-size: 0.95rem;
      margin: 0 0 1rem;
    }

    table.lm {
      width: 100%;
      border-collapse: collapse;
      background: var(--lm-bg-2);
      border: 1px solid var(--lm-border);
      border-radius: 3px;
      overflow: hidden;
      font-size: 0.9rem;
    }
    table.lm th,
    table.lm td {
      text-align: left;
      padding: 0.55rem 0.8rem;
      border-bottom: 1px solid var(--lm-border-soft);
      vertical-align: top;
    }
    table.lm tr:last-child td { border-bottom: none; }
    table.lm th {
      font-family: var(--lm-mono);
      font-size: 0.7rem;
      text-transform: lowercase;
      letter-spacing: 0.1em;
      color: var(--lm-muted);
      background: var(--lm-bg);
      font-weight: 500;
      border-bottom: 1px solid var(--lm-border);
    }
    table.lm td.mono {
      font-family: var(--lm-mono);
      font-size: 0.82rem;
      color: var(--lm-dim);
    }
    table.lm td.num {
      text-align: left;
      color: var(--lm-accent);
    }
    table.lm td.muted {
      color: var(--lm-muted);
      font-size: 0.88rem;
    }

    /* chain svg */
    .chain-wrap {
      background: var(--lm-bg-2);
      border: 1px solid var(--lm-border);
      border-radius: 3px;
      padding: 1rem;
      overflow-x: auto;
    }
    .chain-svg {
      display: block;
      max-width: 100%;
      height: auto;
      margin: 0 auto;
    }

    /* interests check line */
    .check {
      display: flex;
      flex-wrap: wrap;
      gap: 1.2rem;
      margin: 0.9rem 0 0;
      font-family: var(--lm-mono);
      font-size: 0.76rem;
      color: var(--lm-ok);
    }

    /* exceptions */
    .exc {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.6rem;
    }
    .exc li {
      background: var(--lm-bg-2);
      border: 1px solid var(--lm-border);
      border-left-width: 3px;
      border-radius: 3px;
      padding: 0.8rem 1.1rem;
    }
    .exc li[data-severity="blocking"] { border-left-color: var(--lm-err); }
    .exc li[data-severity="curable"] { border-left-color: var(--lm-warn); }
    .exc li[data-severity="noted"] { border-left-color: var(--lm-dim); }
    .exc-head {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      margin-bottom: 0.3rem;
    }
    .chip {
      display: inline-block;
      padding: 0.08rem 0.5rem;
      border-radius: 2px;
      font-family: var(--lm-mono);
      font-size: 0.66rem;
      text-transform: lowercase;
      letter-spacing: 0.08em;
      color: var(--lm-bg);
    }
    .chip-blocking { background: var(--lm-err); color: #fff; }
    .chip-curable { background: var(--lm-warn); color: var(--lm-bg); }
    .chip-noted { background: var(--lm-dim); color: var(--lm-bg); }
    .exc p { margin: 0; color: var(--lm-dim); font-size: 0.95rem; }

    /* opinion document */
    .opinion {
      background: #f7f3e8;
      color: #1a1a1a;
      padding: 2rem 2.4rem;
      border-radius: 3px;
      font-family: 'STIX Two Text', Georgia, serif;
      font-size: 0.98rem;
      line-height: 1.6;
      border: 1px solid #d8d0bd;
    }
    .opinion header {
      border-bottom: 2px solid #c8c0ab;
      padding-bottom: 1rem;
      margin-bottom: 1.2rem;
    }
    .opinion .op-kicker {
      font-family: var(--lm-mono);
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #b35a3a;
      margin: 0 0 0.5rem;
    }
    .opinion .op-to {
      margin: 0;
      font-size: 0.95rem;
    }
    .opinion h4 {
      font-family: 'STIX Two Text', Georgia, serif;
      font-weight: 500;
      font-size: 1.05rem;
      margin: 1.4rem 0 0.5rem;
      color: #1a1a1a;
    }
    .opinion strong { color: #1a1a1a; }
    .opinion ul,
    .opinion ol {
      padding-left: 1.4rem;
      margin: 0.4rem 0 0.6rem;
    }
    .opinion li {
      margin-bottom: 0.4rem;
    }
    .opinion footer {
      margin-top: 2rem;
      padding-top: 1rem;
      border-top: 1px solid #c8c0ab;
    }
    .opinion .op-sig {
      margin: 0;
      font-size: 0.88rem;
      color: #555;
    }
    .opinion .op-sig em {
      font-size: 0.78rem;
    }

    /* residual list */
    .residual {
      list-style: none;
      padding: 0;
      margin: 1rem 0 2rem;
      display: grid;
      gap: 0.6rem;
    }
    .residual li {
      background: var(--lm-bg-2);
      border: 1px solid var(--lm-border);
      border-radius: 3px;
      padding: 0.7rem 1.1rem;
      font-size: 0.98rem;
    }

    /* responsive */
    @media (max-width: 700px) {
      .steps li {
        grid-template-columns: 1.2rem 1fr;
        grid-template-areas:
          "glyph name"
          ".     detail"
          ".     time";
      }
      .steps li .glyph { grid-area: glyph; }
      .steps li .name { grid-area: name; }
      .steps li .detail { grid-area: detail; white-space: normal; }
      .steps li .time { grid-area: time; text-align: left; }
      .summary-quick { margin-left: 0; }
    }
  </style>
</Landman>
