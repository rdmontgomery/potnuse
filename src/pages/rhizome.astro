---
import Base from '@/layouts/Base.astro';
import { buildGraph } from '@/lib/graph';

const graph = await buildGraph();

// Build an id set so edges only point at nodes we actually have.
const ids = new Set(graph.map((n) => n.slug));
const edges: Array<{ source: string; target: string }> = [];
for (const node of graph) {
  for (const target of node.connects) {
    // `connects` entries are slugs; defend against typos silently.
    if (ids.has(target) && target !== node.slug) {
      edges.push({ source: node.slug, target });
    }
  }
}

const payload = {
  nodes: graph.map((n) => ({
    slug: n.slug,
    title: n.title,
    collection: n.collection,
    state: n.state,
    url: n.url,
    degree: n.connects.length + n.backlinks.length,
  })),
  edges,
};
---

<Base
  title="rhizome"
  description="the graph underneath — every page and its connections"
>
  <main class="rhizome">
    <header>
      <h1>rhizome</h1>
      <p class="sub">every page, every edge. drag a node. click to enter.</p>
      <ul class="legend" aria-label="legend">
        <li><span class="dot essays"></span>essays</li>
        <li><span class="dot experiments"></span>experiments</li>
        <li><span class="dot exchanges"></span>exchanges</li>
        <li><span class="dot page"></span>pages</li>
      </ul>
    </header>
    <div class="stage">
      <canvas id="graph" aria-label="rhizome graph"></canvas>
      <div id="label" class="label" aria-hidden="true"></div>
    </div>
  </main>
</Base>

<script define:vars={{ payload }}>
  const COLORS = {
    essays: '#e8a838',
    experiments: '#7fb069',
    exchanges: '#c48ac9',
    page: '#9e8e72',
  };
  const TEXT_DIM = '#9e8e72';
  const EDGE = 'rgba(158, 142, 114, 0.35)';

  const canvas = document.getElementById('graph');
  const label = document.getElementById('label');
  if (!(canvas instanceof HTMLCanvasElement) || !label) {
    throw new Error('rhizome: canvas missing');
  }
  const ctx = canvas.getContext('2d');
  if (!ctx) throw new Error('rhizome: 2d context unavailable');

  /** @type {Array<{slug:string,title:string,collection:string,state:string,url:string,degree:number,x:number,y:number,vx:number,vy:number,r:number}>} */
  const nodes = payload.nodes.map((n) => ({
    ...n,
    x: Math.random() * 800 - 400,
    y: Math.random() * 600 - 300,
    vx: 0,
    vy: 0,
    r: 4 + Math.sqrt(n.degree) * 2.2,
  }));
  const nodeBySlug = new Map(nodes.map((n) => [n.slug, n]));
  const edges = payload.edges
    .map((e) => ({
      source: nodeBySlug.get(e.source),
      target: nodeBySlug.get(e.target),
    }))
    .filter((e) => e.source && e.target);

  let width = 0;
  let height = 0;
  let dpr = Math.min(window.devicePixelRatio || 1, 2);

  function resize() {
    const rect = canvas.getBoundingClientRect();
    width = rect.width;
    height = rect.height;
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.floor(width * dpr);
    canvas.height = Math.floor(height * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resize();
  window.addEventListener('resize', resize);

  // --- force simulation (Fruchterman-Reingold-ish, dependency-free) ---
  const LINK_DIST = 110;
  const LINK_STRENGTH = 0.04;
  const CHARGE = 1400;
  const CENTER = 0.015;
  const DAMPING = 0.82;

  function step() {
    const cx = 0;
    const cy = 0;

    // Repulsion (O(n^2), fine for < ~300 nodes).
    for (let i = 0; i < nodes.length; i++) {
      const a = nodes[i];
      for (let j = i + 1; j < nodes.length; j++) {
        const b = nodes[j];
        let dx = a.x - b.x;
        let dy = a.y - b.y;
        let dist2 = dx * dx + dy * dy;
        if (dist2 < 0.01) {
          dx = Math.random() - 0.5;
          dy = Math.random() - 0.5;
          dist2 = dx * dx + dy * dy + 0.01;
        }
        const dist = Math.sqrt(dist2);
        const force = CHARGE / dist2;
        const fx = (dx / dist) * force;
        const fy = (dy / dist) * force;
        a.vx += fx;
        a.vy += fy;
        b.vx -= fx;
        b.vy -= fy;
      }
    }

    // Link attraction.
    for (const e of edges) {
      const dx = e.target.x - e.source.x;
      const dy = e.target.y - e.source.y;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      const delta = (dist - LINK_DIST) * LINK_STRENGTH;
      const fx = (dx / dist) * delta;
      const fy = (dy / dist) * delta;
      e.source.vx += fx;
      e.source.vy += fy;
      e.target.vx -= fx;
      e.target.vy -= fy;
    }

    // Centering + integrate.
    for (const n of nodes) {
      n.vx += (cx - n.x) * CENTER;
      n.vy += (cy - n.y) * CENTER;
      n.vx *= DAMPING;
      n.vy *= DAMPING;
      if (n !== dragging) {
        n.x += n.vx;
        n.y += n.vy;
      }
    }
  }

  // --- pan/zoom in view coords ---
  let tx = 0;
  let ty = 0;
  let scale = 1;

  function worldToScreen(x, y) {
    return { x: (x + tx) * scale + width / 2, y: (y + ty) * scale + height / 2 };
  }
  function screenToWorld(sx, sy) {
    return {
      x: (sx - width / 2) / scale - tx,
      y: (sy - height / 2) / scale - ty,
    };
  }

  function draw() {
    ctx.clearRect(0, 0, width, height);

    ctx.save();
    ctx.translate(width / 2, height / 2);
    ctx.scale(scale, scale);
    ctx.translate(tx, ty);

    // edges (directed: source -> target)
    ctx.strokeStyle = EDGE;
    ctx.fillStyle = EDGE;
    ctx.lineWidth = 1 / scale;
    const arrowLen = 8 / scale;
    const arrowWidth = 4 / scale;
    for (const e of edges) {
      const dx = e.target.x - e.source.x;
      const dy = e.target.y - e.source.y;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      const ux = dx / dist;
      const uy = dy / dist;
      // stop the line short of the target node so the arrowhead sits on the rim
      const tipX = e.target.x - ux * e.target.r;
      const tipY = e.target.y - uy * e.target.r;
      const baseX = tipX - ux * arrowLen;
      const baseY = tipY - uy * arrowLen;
      ctx.beginPath();
      ctx.moveTo(e.source.x, e.source.y);
      ctx.lineTo(baseX, baseY);
      ctx.stroke();
      // arrowhead
      const px = -uy;
      const py = ux;
      ctx.beginPath();
      ctx.moveTo(tipX, tipY);
      ctx.lineTo(baseX + px * arrowWidth, baseY + py * arrowWidth);
      ctx.lineTo(baseX - px * arrowWidth, baseY - py * arrowWidth);
      ctx.closePath();
      ctx.fill();
    }

    // nodes
    for (const n of nodes) {
      ctx.fillStyle = COLORS[n.collection] || TEXT_DIM;
      ctx.globalAlpha = n.state === 'fossil' ? 0.55 : 1;
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;

    // highlight hovered
    if (hovered) {
      ctx.strokeStyle = '#f0e6d2';
      ctx.lineWidth = 2 / scale;
      ctx.beginPath();
      ctx.arc(hovered.x, hovered.y, hovered.r + 3 / scale, 0, Math.PI * 2);
      ctx.stroke();
    }

    ctx.restore();
  }

  let hovered = null;
  let dragging = null;
  let dragMoved = false;
  let panning = false;
  let panStart = { x: 0, y: 0 };
  let panOrigin = { x: 0, y: 0 };

  function nodeAt(sx, sy) {
    const w = screenToWorld(sx, sy);
    for (let i = nodes.length - 1; i >= 0; i--) {
      const n = nodes[i];
      const dx = n.x - w.x;
      const dy = n.y - w.y;
      const r = n.r + 4 / scale;
      if (dx * dx + dy * dy <= r * r) return n;
    }
    return null;
  }

  canvas.addEventListener('mousemove', (ev) => {
    const rect = canvas.getBoundingClientRect();
    const sx = ev.clientX - rect.left;
    const sy = ev.clientY - rect.top;

    if (dragging) {
      const w = screenToWorld(sx, sy);
      dragging.x = w.x;
      dragging.y = w.y;
      dragging.vx = 0;
      dragging.vy = 0;
      dragMoved = true;
      return;
    }
    if (panning) {
      tx = panOrigin.x + (sx - panStart.x) / scale;
      ty = panOrigin.y + (sy - panStart.y) / scale;
      return;
    }

    const n = nodeAt(sx, sy);
    hovered = n;
    canvas.style.cursor = n ? 'pointer' : 'grab';
    if (n) {
      const screen = worldToScreen(n.x, n.y);
      label.textContent = n.title;
      label.style.left = `${screen.x}px`;
      label.style.top = `${screen.y - n.r * scale - 10}px`;
      label.classList.add('is-visible');
    } else {
      label.classList.remove('is-visible');
    }
  });

  canvas.addEventListener('mousedown', (ev) => {
    const rect = canvas.getBoundingClientRect();
    const sx = ev.clientX - rect.left;
    const sy = ev.clientY - rect.top;
    const n = nodeAt(sx, sy);
    if (n) {
      dragging = n;
      dragMoved = false;
      canvas.style.cursor = 'grabbing';
    } else {
      panning = true;
      panStart = { x: sx, y: sy };
      panOrigin = { x: tx, y: ty };
      canvas.style.cursor = 'grabbing';
    }
  });

  window.addEventListener('mouseup', () => {
    if (dragging && !dragMoved) {
      window.location.href = dragging.url;
    }
    dragging = null;
    panning = false;
    canvas.style.cursor = hovered ? 'pointer' : 'grab';
  });

  canvas.addEventListener('wheel', (ev) => {
    ev.preventDefault();
    const rect = canvas.getBoundingClientRect();
    const sx = ev.clientX - rect.left;
    const sy = ev.clientY - rect.top;
    const before = screenToWorld(sx, sy);
    const factor = Math.exp(-ev.deltaY * 0.001);
    scale = Math.max(0.25, Math.min(3, scale * factor));
    const after = screenToWorld(sx, sy);
    tx += after.x - before.x;
    ty += after.y - before.y;
  }, { passive: false });

  // keyboard: enter key on focused canvas enters hovered node
  canvas.tabIndex = 0;
  canvas.addEventListener('keydown', (ev) => {
    if (ev.key === 'Enter' && hovered) {
      window.location.href = hovered.url;
    }
  });

  // settle for a few hundred frames without drawing so first paint isn't chaos
  for (let i = 0; i < 240; i++) step();

  function tick() {
    step();
    draw();
    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
</script>

<style>
  .rhizome {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }
  header {
    margin-bottom: 1.5rem;
  }
  header h1 {
    font-family: 'EB Garamond', Georgia, serif;
    font-weight: 500;
    font-size: 2.2rem;
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
  }
  .sub {
    color: var(--text-dim);
    font-style: italic;
    margin: 0 0 1rem;
  }
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-jetbrains);
    font-size: 0.72rem;
    color: var(--text-dim);
    text-transform: lowercase;
    letter-spacing: 0.08em;
  }
  .legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .dot {
    display: inline-block;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
  }
  .dot.essays {
    background: #e8a838;
  }
  .dot.experiments {
    background: #7fb069;
  }
  .dot.exchanges {
    background: #c48ac9;
  }
  .dot.page {
    background: #9e8e72;
  }
  .stage {
    position: relative;
    height: min(78vh, 820px);
    background: #1e1609;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    touch-action: none;
  }
  canvas {
    display: block;
    width: 100%;
    height: 100%;
    cursor: grab;
  }
  .label {
    position: absolute;
    transform: translate(-50%, -100%);
    pointer-events: none;
    background: var(--bg-card);
    color: var(--text);
    border: 1px solid var(--border);
    padding: 0.25rem 0.55rem;
    font-family: var(--font-jetbrains);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.12s ease;
  }
  .label.is-visible {
    opacity: 1;
  }
</style>
