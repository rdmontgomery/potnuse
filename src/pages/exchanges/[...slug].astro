---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Backlinks from '@/components/Backlinks.astro';
import StateBadge from '@/components/StateBadge.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const exchanges = await getCollection('exchanges');
  return exchanges.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await render(entry);
const toc = entry.data.toc;
const hasToc = !!toc && toc.length > 0;
---

<Base title={entry.data.title} description={entry.data.description}>
  <article class:list={['exchange', { 'has-toc': hasToc }]}>
    {
      hasToc && (
        <nav class="toc" aria-label="sections">
          {toc.map((item) => (
            <a href={`#${item.id}`} data-toc>
              {item.label}
            </a>
          ))}
        </nav>
      )
    }
    <div class="main">
      <header>
        <h1>{entry.data.title}</h1>
        <div class="meta">
          <StateBadge state={entry.data.state} />
          <span class="with">with {entry.data.with}</span>
          {
            entry.data.date && (
              <time datetime={entry.data.date.toISOString()}>
                {entry.data.date.toISOString().slice(0, 10)}
              </time>
            )
          }
        </div>
      </header>
      <div class="prose">
        <Content />
      </div>
      <Backlinks slug={entry.id} />
    </div>
  </article>
</Base>

{
  hasToc && (
    <script>
      const tocLinks = Array.from(
        document.querySelectorAll<HTMLAnchorElement>('.toc a[data-toc]'),
      );
      const sections = tocLinks
        .map((link) => document.querySelector(link.getAttribute('href') || ''))
        .filter((s): s is Element => !!s);

      if ('IntersectionObserver' in window && sections.length) {
        const byId = new Map<string, HTMLAnchorElement>();
        tocLinks.forEach((l) => {
          const id = (l.getAttribute('href') || '').slice(1);
          if (id) byId.set(id, l);
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const link = byId.get(entry.target.id);
              if (!link) return;
              if (entry.isIntersecting) {
                tocLinks.forEach((l) => l.classList.remove('is-active'));
                link.classList.add('is-active');
              }
            });
          },
          { rootMargin: '-20% 0px -60% 0px', threshold: 0 },
        );
        sections.forEach((s) => observer.observe(s));
      }
    </script>
  )
}

<style>
  .exchange {
    max-width: 680px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.15rem;
    line-height: 1.6;
  }

  .exchange.has-toc {
    display: grid;
    grid-template-columns: 1fr;
    max-width: 1100px;
    gap: 3rem;
  }

  .toc {
    display: none;
  }

  @media (min-width: 1080px) {
    .exchange.has-toc {
      grid-template-columns: 200px 1fr;
      gap: 4rem;
      max-width: 1200px;
    }
    .exchange.has-toc .main {
      max-width: 720px;
    }
    .toc {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      position: sticky;
      top: 3rem;
      align-self: start;
      font-family: var(--font-jetbrains);
      font-size: 0.72rem;
      text-transform: lowercase;
      letter-spacing: 0.08em;
      padding-top: 0.4rem;
      max-height: calc(100vh - 4rem);
      overflow-y: auto;
    }
    .toc a {
      color: var(--text-muted);
      text-decoration: none;
      border-left: 1px solid var(--border);
      padding: 0.2rem 0 0.2rem 0.8rem;
      line-height: 1.4;
      transition:
        color 0.2s ease,
        border-color 0.2s ease;
    }
    .toc a:hover,
    .toc a.is-active {
      color: var(--accent);
      border-left-color: var(--accent);
    }
  }

  /* Anchor targets injected at section boundaries in MDX.
     Offset for sticky headers and give the IntersectionObserver
     a stable element to watch. */
  .prose :global([data-toc-target]) {
    display: block;
    height: 0;
    overflow: visible;
    scroll-margin-top: 2rem;
    position: relative;
  }

  header h1 {
    font-family: 'EB Garamond', Georgia, serif;
    font-weight: 500;
    font-size: 2.6rem;
    margin: 0 0 0.75rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .meta {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    color: var(--text-dim);
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  .meta time {
    font-family: var(--font-jetbrains);
    font-size: 0.75rem;
  }
  .with {
    font-family: 'EB Garamond', Georgia, serif;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--text-dim);
    letter-spacing: 0.01em;
  }
  .prose :global(p) {
    margin: 1.2em 0;
  }
  .prose :global(a) {
    color: var(--text);
    border-bottom: 1px solid rgba(232, 168, 56, 0.5);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .prose :global(a:hover) {
    color: var(--accent);
  }
  .prose :global(h2) {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.45rem;
    margin: 2.5em 0 0.5em;
    font-weight: 500;
  }
  .prose :global(h3) {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.2rem;
    margin: 2em 0 0.5em;
    font-weight: 500;
    font-style: italic;
    color: var(--text);
  }
  .prose :global(em) {
    font-style: italic;
  }
  .prose :global(strong) {
    font-weight: 600;
  }
  /* Claude's pulled voice — STIX Two Text */
  .prose :global(blockquote) {
    font-family: 'STIX Two Text', Georgia, serif;
    font-size: 1rem;
    line-height: 1.65;
    font-style: normal;
    color: var(--text-dim);
    border-left: 2px solid var(--accent-dim);
    margin: 1.8em 0;
    padding: 0.3em 0 0.3em 1.3em;
  }
  .prose :global(blockquote p) {
    margin: 0.7em 0;
  }
  .prose :global(blockquote p:first-child) {
    margin-top: 0;
  }
  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
  .prose :global(blockquote em) {
    font-style: italic;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3em auto;
    width: 30%;
  }
  .prose :global(abbr[title]) {
    text-decoration: none;
    border-bottom: 1px dotted var(--accent-dim);
    cursor: help;
  }
  .prose :global(blockquote abbr[title]) {
    border-bottom-color: rgba(158, 142, 114, 0.6);
  }
</style>
