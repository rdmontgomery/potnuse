---
import Base from '@/layouts/Base.astro';
---

<Base
  title="lift"
  description="Kettlebell circuit tracker with a stronglifts-style progression. Mobile-first, localStorage."
>
  <main class="lift">
    <header class="head">
      <p class="kicker">circuit · stronglifts-style</p>
      <h1 class="title">lift</h1>
      <p class="phase" data-phase></p>
    </header>

    <section class="card today" aria-label="today's session">
      <p class="kicker today-label">today</p>
      <div class="prescription">
        <div class="rx">
          <span class="rx-num" data-bell></span>
          <span class="rx-unit">lb</span>
        </div>
        <div class="rx-sep">·</div>
        <div class="rx">
          <span class="rx-num" data-target></span>
          <span class="rx-unit">rounds</span>
        </div>
      </div>

      <ol class="exercises">
        <li><span class="rep">6</span> curl-to-overhead + halo (CW/CCW)</li>
        <li><span class="rep">12</span> reverse lunges (alt 6/side)</li>
        <li><span class="rep">6</span> bicep curls</li>
        <li><span class="rep">12</span> single-leg RDL (6/side)</li>
        <li><span class="rep">12</span> bent-over rows (6/side)</li>
      </ol>

      <div class="rounds" data-rounds aria-label="rounds completed"></div>

      <details class="tgu">
        <summary>turkish get-ups (optional)</summary>
        <div class="tgu-body">
          <p class="tgu-hint">3/side recommended at current bell.</p>
          <div class="tgu-controls">
            <button type="button" class="step" data-tgu-step="-1" aria-label="decrement">−</button>
            <span class="tgu-count" data-tgu>0</span>
            <button type="button" class="step" data-tgu-step="1" aria-label="increment">+</button>
          </div>
        </div>
      </details>

      <label class="clean-row">
        <input type="checkbox" data-clean checked />
        <span>clean form throughout</span>
      </label>

      <textarea
        class="notes"
        data-notes
        rows="2"
        placeholder="notes (optional) — how it felt, what broke down…"
      ></textarea>

      <div class="actions">
        <button type="button" class="btn primary" data-save>log session</button>
        <button type="button" class="btn" data-reset-rounds>reset</button>
      </div>
    </section>

    <section class="card progress" aria-label="progression">
      <p class="kicker">progression</p>
      <ol class="ladder" data-ladder></ol>
      <p class="rule">
        Advance when you complete the round target with clean form on
        two sessions in a row. Miss two in a row → drop one round.
      </p>
    </section>

    <section class="card history" aria-label="history">
      <p class="kicker">history</p>
      <p class="streak" data-streak></p>
      <ul class="log" data-log></ul>
      <div class="actions secondary">
        <button type="button" class="btn ghost" data-export>export json</button>
        <label class="btn ghost file">
          import
          <input type="file" accept="application/json" data-import hidden />
        </label>
        <button type="button" class="btn ghost danger" data-clear>clear all</button>
      </div>
    </section>

    <footer class="foot">
      <p>
        Stored locally on this device. Loads from your phone, your
        phone keeps the log.
      </p>
    </footer>
  </main>
</Base>

<script>
  type Session = {
    date: string;
    bell: number;
    target: number;
    rounds: number;
    clean: boolean;
    tgu: number;
    notes: string;
  };

  type Phase = { bell: number; target: number };

  const LADDER: Phase[] = [
    { bell: 25, target: 2 },
    { bell: 25, target: 3 },
    { bell: 25, target: 4 },
    { bell: 35, target: 2 },
    { bell: 35, target: 3 },
    { bell: 35, target: 4 },
    { bell: 35, target: 5 },
  ];

  const STORAGE_KEY = 'lift.sessions.v1';
  const STATE_KEY = 'lift.state.v1';

  type LiveState = { rounds: number; tgu: number; clean: boolean; notes: string };

  function loadSessions(): Session[] {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return [];
      const arr = JSON.parse(raw);
      return Array.isArray(arr) ? arr : [];
    } catch {
      return [];
    }
  }

  function saveSessions(s: Session[]) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(s));
  }

  function loadState(): LiveState {
    try {
      const raw = localStorage.getItem(STATE_KEY);
      if (!raw) return { rounds: 0, tgu: 0, clean: true, notes: '' };
      return { rounds: 0, tgu: 0, clean: true, notes: '', ...JSON.parse(raw) };
    } catch {
      return { rounds: 0, tgu: 0, clean: true, notes: '' };
    }
  }

  function saveState(s: LiveState) {
    localStorage.setItem(STATE_KEY, JSON.stringify(s));
  }

  function clearState() {
    localStorage.removeItem(STATE_KEY);
  }

  // Current phase = highest phase where the previous phase has been
  // completed cleanly twice in a row, walking up from the bottom.
  function currentPhaseIndex(sessions: Session[]): number {
    let idx = 0;
    for (let i = 0; i < LADDER.length - 1; i++) {
      const phase = LADDER[i];
      const matching = sessions.filter(
        (s) => s.bell === phase.bell && s.target === phase.target
      );
      const last2 = matching.slice(-2);
      const advanced =
        last2.length === 2 &&
        last2.every((s) => s.clean && s.rounds >= phase.target);
      if (advanced) idx = i + 1;
      else break;
    }
    // Demote if last 2 sessions at the current target both failed.
    const cur = LADDER[idx];
    const atCur = sessions.filter(
      (s) => s.bell === cur.bell && s.target === cur.target
    );
    const last2 = atCur.slice(-2);
    if (
      idx > 0 &&
      last2.length === 2 &&
      last2.every((s) => !s.clean || s.rounds < cur.target)
    ) {
      return idx - 1;
    }
    return idx;
  }

  function streakAt(sessions: Session[], idx: number): {
    clean: number;
    needed: number;
  } {
    const phase = LADDER[idx];
    let clean = 0;
    for (let i = sessions.length - 1; i >= 0; i--) {
      const s = sessions[i];
      if (s.bell !== phase.bell || s.target !== phase.target) break;
      if (s.clean && s.rounds >= phase.target) clean++;
      else break;
    }
    const isLast = idx === LADDER.length - 1;
    return { clean, needed: isLast ? Infinity : 2 };
  }

  function fmtDate(iso: string): string {
    const d = new Date(iso);
    return d.toLocaleDateString(undefined, {
      month: 'short',
      day: 'numeric',
    });
  }

  function render() {
    const sessions = loadSessions();
    const state = loadState();
    const idx = currentPhaseIndex(sessions);
    const phase = LADDER[idx];

    const $ = <T extends Element>(sel: string) =>
      document.querySelector(sel) as T | null;

    const bellEl = $<HTMLElement>('[data-bell]');
    const targetEl = $<HTMLElement>('[data-target]');
    const phaseEl = $<HTMLElement>('[data-phase]');
    const roundsEl = $<HTMLElement>('[data-rounds]');
    const tguEl = $<HTMLElement>('[data-tgu]');
    const cleanEl = $<HTMLInputElement>('[data-clean]');
    const notesEl = $<HTMLTextAreaElement>('[data-notes]');
    const ladderEl = $<HTMLElement>('[data-ladder]');
    const logEl = $<HTMLElement>('[data-log]');
    const streakEl = $<HTMLElement>('[data-streak]');

    if (bellEl) bellEl.textContent = String(phase.bell);
    if (targetEl) targetEl.textContent = String(phase.target);

    const totalPhases = LADDER.length;
    if (phaseEl) {
      phaseEl.textContent = `phase ${idx + 1} of ${totalPhases}`;
    }

    // round dots — show target + 1 spare so you can record a bonus round
    if (roundsEl) {
      roundsEl.innerHTML = '';
      const dots = phase.target + 1;
      for (let i = 0; i < dots; i++) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'round-dot';
        b.setAttribute('data-round-idx', String(i));
        if (i < state.rounds) b.classList.add('done');
        if (i === phase.target) b.classList.add('bonus');
        b.innerHTML = `<span class="dot-num">${i + 1}</span>`;
        b.setAttribute(
          'aria-label',
          `${i < state.rounds ? 'completed' : 'mark'} round ${i + 1}`
        );
        roundsEl.appendChild(b);
      }
    }

    if (tguEl) tguEl.textContent = String(state.tgu);
    if (cleanEl) cleanEl.checked = state.clean;
    if (notesEl) notesEl.value = state.notes;

    // ladder
    if (ladderEl) {
      ladderEl.innerHTML = '';
      LADDER.forEach((p, i) => {
        const li = document.createElement('li');
        li.className = 'rung';
        if (i < idx) li.classList.add('done');
        if (i === idx) li.classList.add('current');
        const matches = sessions.filter(
          (s) => s.bell === p.bell && s.target === p.target
        ).length;
        li.innerHTML = `
          <span class="rung-bell">${p.bell}lb</span>
          <span class="rung-target">${p.target} rounds</span>
          <span class="rung-count">${matches > 0 ? `${matches}×` : ''}</span>
        `;
        ladderEl.appendChild(li);
      });
    }

    // streak
    if (streakEl) {
      const { clean, needed } = streakAt(sessions, idx);
      if (sessions.length === 0) {
        streakEl.textContent = 'no sessions yet — log your first';
      } else if (idx === LADDER.length - 1) {
        streakEl.textContent = `top of the ladder · time to find a heavier bell`;
      } else if (clean === 0) {
        streakEl.textContent = `${needed} clean sessions to advance`;
      } else {
        streakEl.textContent = `${clean}/${needed} toward the next rung`;
      }
    }

    // log
    if (logEl) {
      logEl.innerHTML = '';
      const recent = sessions.slice().reverse().slice(0, 20);
      if (recent.length === 0) {
        const li = document.createElement('li');
        li.className = 'log-empty';
        li.textContent = 'nothing yet';
        logEl.appendChild(li);
      } else {
        recent.forEach((s, i) => {
          const li = document.createElement('li');
          li.className = 'log-row';
          if (!s.clean) li.classList.add('not-clean');
          const tgu = s.tgu > 0 ? ` · ${s.tgu} TGU` : '';
          const flag = s.clean ? '' : ' · ground';
          li.innerHTML = `
            <span class="log-date">${fmtDate(s.date)}</span>
            <span class="log-body">${s.bell}lb · ${s.rounds}/${s.target}${tgu}${flag}</span>
            <button type="button" class="log-del" data-del-idx="${sessions.length - 1 - i}" aria-label="delete session">×</button>
          `;
          logEl.appendChild(li);
        });
      }
    }
  }

  function bind() {
    document.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement;
      const dot = t.closest<HTMLElement>('.round-dot');
      if (dot) {
        const idx = Number(dot.getAttribute('data-round-idx'));
        const state = loadState();
        // tap a dot to set rounds = idx+1; tap the current last to undo
        state.rounds = state.rounds === idx + 1 ? idx : idx + 1;
        saveState(state);
        render();
        return;
      }

      const tguBtn = t.closest<HTMLElement>('[data-tgu-step]');
      if (tguBtn) {
        const step = Number(tguBtn.getAttribute('data-tgu-step'));
        const state = loadState();
        state.tgu = Math.max(0, state.tgu + step);
        saveState(state);
        render();
        return;
      }

      const del = t.closest<HTMLElement>('[data-del-idx]');
      if (del) {
        const idx = Number(del.getAttribute('data-del-idx'));
        const sessions = loadSessions();
        if (sessions[idx] && confirm('delete this session?')) {
          sessions.splice(idx, 1);
          saveSessions(sessions);
          render();
        }
        return;
      }
    });

    document
      .querySelector<HTMLInputElement>('[data-clean]')
      ?.addEventListener('change', (ev) => {
        const state = loadState();
        state.clean = (ev.target as HTMLInputElement).checked;
        saveState(state);
      });

    document
      .querySelector<HTMLTextAreaElement>('[data-notes]')
      ?.addEventListener('input', (ev) => {
        const state = loadState();
        state.notes = (ev.target as HTMLTextAreaElement).value;
        saveState(state);
      });

    document.querySelector('[data-save]')?.addEventListener('click', () => {
      const state = loadState();
      if (state.rounds === 0) {
        if (!confirm('log a session with 0 rounds?')) return;
      }
      const sessions = loadSessions();
      const idx = currentPhaseIndex(sessions);
      const phase = LADDER[idx];
      const session: Session = {
        date: new Date().toISOString(),
        bell: phase.bell,
        target: phase.target,
        rounds: state.rounds,
        clean: state.clean,
        tgu: state.tgu,
        notes: state.notes,
      };
      sessions.push(session);
      saveSessions(sessions);
      clearState();
      render();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    document
      .querySelector('[data-reset-rounds]')
      ?.addEventListener('click', () => {
        clearState();
        render();
      });

    document.querySelector('[data-export]')?.addEventListener('click', () => {
      const sessions = loadSessions();
      const blob = new Blob([JSON.stringify(sessions, null, 2)], {
        type: 'application/json',
      });
      const a = document.createElement('a');
      const url = URL.createObjectURL(blob);
      a.href = url;
      a.download = `lift-${new Date().toISOString().slice(0, 10)}.json`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    });

    document
      .querySelector<HTMLInputElement>('[data-import]')
      ?.addEventListener('change', async (ev) => {
        const input = ev.target as HTMLInputElement;
        const file = input.files?.[0];
        if (!file) return;
        try {
          const text = await file.text();
          const data = JSON.parse(text);
          if (!Array.isArray(data)) throw new Error('expected an array');
          if (
            confirm(
              `import ${data.length} sessions? this replaces your current log.`
            )
          ) {
            saveSessions(data);
            render();
          }
        } catch {
          alert('that file does not look like a lift export.');
        } finally {
          input.value = '';
        }
      });

    document.querySelector('[data-clear]')?.addEventListener('click', () => {
      if (
        confirm(
          'clear all sessions? this cannot be undone (export first if you want a backup).'
        )
      ) {
        saveSessions([]);
        clearState();
        render();
      }
    });
  }

  render();
  bind();
</script>

<style>
  .lift {
    max-width: 560px;
    margin: 0 auto;
    padding: 2rem 1.1rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .head {
    text-align: left;
    padding: 0.5rem 0.2rem 0;
  }
  .kicker {
    font-family: var(--font-jetbrains);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    color: var(--text-muted);
    margin: 0 0 0.6rem;
  }
  .title {
    font-family: var(--font-crimson);
    font-size: 2.6rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 0.6rem;
  }
  .phase {
    font-family: var(--font-jetbrains);
    font-size: 0.78rem;
    color: var(--text-dim);
    margin: 0;
    text-transform: lowercase;
    letter-spacing: 0.06em;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.4rem 1.2rem 1.5rem;
  }

  .today-label {
    color: var(--accent-dim);
  }

  .prescription {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0.2rem 0 1.4rem;
  }
  .rx {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
  }
  .rx-num {
    font-family: var(--font-crimson);
    font-size: 2.4rem;
    font-weight: 500;
    line-height: 1;
    color: var(--accent);
    letter-spacing: -0.02em;
  }
  .rx-unit {
    font-family: var(--font-jetbrains);
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: lowercase;
  }
  .rx-sep {
    color: var(--text-muted);
    font-size: 1.4rem;
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .exercises {
    list-style: none;
    padding: 0;
    margin: 0 0 1.4rem;
    display: grid;
    gap: 0.45rem;
  }
  .exercises li {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.4;
  }
  .exercises .rep {
    font-family: var(--font-jetbrains);
    font-size: 0.82rem;
    color: var(--accent-dim);
    min-width: 1.6em;
    flex-shrink: 0;
  }

  .rounds {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(56px, 1fr));
    gap: 0.5rem;
    margin: 0.4rem 0 1.4rem;
  }
  .round-dot {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: var(--font-jetbrains);
    font-size: 0.95rem;
    border-radius: 6px;
    padding: 0.85rem 0;
    cursor: pointer;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease,
      transform 0.1s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .round-dot:active {
    transform: scale(0.96);
  }
  .round-dot.bonus {
    border-style: dashed;
    color: var(--text-muted);
  }
  .round-dot.done {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
  }
  .round-dot.done.bonus {
    background: var(--accent-dim);
    border-style: solid;
    border-color: var(--accent-dim);
    color: var(--bg);
  }

  .tgu {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    margin-bottom: 1rem;
  }
  .tgu > summary {
    cursor: pointer;
    list-style: none;
    font-family: var(--font-jetbrains);
    font-size: 0.78rem;
    color: var(--text-dim);
    text-transform: lowercase;
    letter-spacing: 0.06em;
  }
  .tgu > summary::-webkit-details-marker {
    display: none;
  }
  .tgu > summary::before {
    content: '+ ';
    color: var(--text-muted);
  }
  .tgu[open] > summary::before {
    content: '− ';
    color: var(--accent-dim);
  }
  .tgu-body {
    margin-top: 0.9rem;
  }
  .tgu-hint {
    font-size: 0.88rem;
    color: var(--text-dim);
    margin: 0 0 0.7rem;
  }
  .tgu-controls {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.3rem 0.6rem;
  }
  .step {
    background: none;
    border: none;
    color: var(--text);
    font-size: 1.3rem;
    width: 2rem;
    height: 2rem;
    border-radius: 4px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .step:active {
    background: var(--bg-button);
  }
  .tgu-count {
    font-family: var(--font-jetbrains);
    font-size: 1.1rem;
    color: var(--accent);
    min-width: 1.5em;
    text-align: center;
  }

  .clean-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 1rem;
    color: var(--text);
    font-size: 0.95rem;
    cursor: pointer;
    user-select: none;
  }
  .clean-row input {
    appearance: none;
    width: 1.1rem;
    height: 1.1rem;
    border: 1px solid var(--border);
    background: var(--bg);
    border-radius: 3px;
    display: grid;
    place-items: center;
    cursor: pointer;
    flex-shrink: 0;
  }
  .clean-row input:checked {
    background: var(--accent);
    border-color: var(--accent);
  }
  .clean-row input:checked::after {
    content: '';
    width: 0.55rem;
    height: 0.3rem;
    border-left: 2px solid var(--bg);
    border-bottom: 2px solid var(--bg);
    transform: rotate(-45deg) translate(1px, -1px);
  }

  .notes {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-crimson);
    font-size: 0.95rem;
    line-height: 1.45;
    padding: 0.7rem 0.8rem;
    border-radius: 4px;
    resize: vertical;
    margin-bottom: 1rem;
  }
  .notes:focus {
    outline: none;
    border-color: var(--accent-dim);
  }

  .actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .actions.secondary {
    margin-top: 1rem;
  }
  .btn {
    background: var(--bg-button);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-jetbrains);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    padding: 0.7rem 1.1rem;
    border-radius: 4px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .btn:active {
    transform: scale(0.98);
  }
  .btn.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
    flex: 1;
    font-weight: 600;
    padding: 0.85rem 1.1rem;
  }
  .btn.primary:hover {
    background: var(--accent-dim);
    border-color: var(--accent-dim);
  }
  .btn.ghost {
    background: transparent;
    color: var(--text-dim);
    font-size: 0.74rem;
    padding: 0.55rem 0.8rem;
  }
  .btn.ghost:hover {
    color: var(--accent);
    border-color: var(--accent-dim);
  }
  .btn.ghost.danger:hover {
    color: #c87060;
    border-color: #6b3a30;
  }
  .btn.file {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
  }

  /* progress */
  .ladder {
    list-style: none;
    padding: 0;
    margin: 0.6rem 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .rung {
    display: grid;
    grid-template-columns: 4em 1fr auto;
    align-items: baseline;
    gap: 0.8rem;
    padding: 0.55rem 0.7rem;
    border-radius: 4px;
