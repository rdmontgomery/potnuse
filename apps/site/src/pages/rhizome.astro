---
import Base from '@/layouts/Base.astro';
import { buildGraph } from '@/lib/graph';

const graph = await buildGraph();

// Build an id set so edges only point at nodes we actually have.
const ids = new Set(graph.map((n) => n.slug));
const edges: Array<{ source: string; target: string }> = [];
for (const node of graph) {
  for (const target of node.connects) {
    // `connects` entries are slugs; defend against typos silently.
    if (ids.has(target) && target !== node.slug) {
      edges.push({ source: node.slug, target });
    }
  }
}

const payload = {
  nodes: graph.map((n) => ({
    slug: n.slug,
    title: n.title,
    collection: n.collection,
    state: n.state,
    url: n.url,
    description: n.description ?? '',
    degree: n.connects.length + n.backlinks.length,
  })),
  edges,
};
---

<Base
  title="rhizome"
  description="the graph underneath — every page and its connections"
>
  <main class="rhizome">
    <header>
      <h1>rhizome</h1>
      <p class="sub">tap a node to focus. tap the focused node to enter. hold to summon a card.</p>
      <ul class="legend" aria-label="legend">
        <li><span class="dot essays"></span>essays</li>
        <li><span class="dot experiments"></span>experiments</li>
        <li><span class="dot exchanges"></span>exchanges</li>
        <li><span class="dot page"></span>pages</li>
      </ul>
    </header>
    <div class="stage">
      <canvas id="graph" aria-label="rhizome graph"></canvas>
      <div id="overlay" class="overlay" aria-hidden="true">
        <div id="hover-label" class="hover-label"></div>
        <div id="focus-labels" class="focus-labels"></div>
        <div id="summon-card" class="summon-card">
          <div class="summon-title"></div>
          <div class="summon-desc"></div>
          <div class="summon-neighbors"></div>
        </div>
      </div>
    </div>
  </main>
</Base>

<script define:vars={{ payload }}>
  const COLORS = {
    essays: '#e8a838',
    experiments: '#7fb069',
    exchanges: '#c48ac9',
    page: '#9e8e72',
  };
  const TEXT_DIM = '#9e8e72';
  const EDGE = 'rgba(158, 142, 114, 0.35)';
  const EDGE_FOCUS = 'rgba(232, 168, 56, 0.65)';
  const HIGHLIGHT = '#f0e6d2';

  const BREATH = {
    seedling: { rate: 1.4 * 2 * Math.PI, amp: 0.08 },
    germinating: { rate: 0.7 * 2 * Math.PI, amp: 0.12 },
    stable: { rate: 0.3 * 2 * Math.PI, amp: 0.03 },
    fossil: { rate: 0, amp: 0 },
  };

  const NEIGHBOR_MAX = 12;
  const LONG_PRESS_MS = 250;
  const MOVE_THRESHOLD = 6; // px before tap becomes drag/pan
  const PARTICLE_SPEED = 42; // world units per second

  const reducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches;

  const canvas = document.getElementById('graph');
  const overlay = document.getElementById('overlay');
  const hoverLabel = document.getElementById('hover-label');
  const focusLabelsEl = document.getElementById('focus-labels');
  const summonCard = document.getElementById('summon-card');
  if (
    !(canvas instanceof HTMLCanvasElement) ||
    !overlay ||
    !hoverLabel ||
    !focusLabelsEl ||
    !summonCard
  ) {
    throw new Error('rhizome: dom missing');
  }
  const summonTitleEl = summonCard.querySelector('.summon-title');
  const summonDescEl = summonCard.querySelector('.summon-desc');
  const summonNeighborsEl = summonCard.querySelector('.summon-neighbors');
  const ctx = canvas.getContext('2d');
  if (!ctx) throw new Error('rhizome: 2d context unavailable');

  const nodes = payload.nodes.map((n) => ({
    ...n,
    x: Math.random() * 800 - 400,
    y: Math.random() * 600 - 300,
    vx: 0,
    vy: 0,
    r: 4 + Math.sqrt(n.degree) * 2.2,
    breathPhase: Math.random() * Math.PI * 2,
  }));
  const nodeBySlug = new Map(nodes.map((n) => [n.slug, n]));
  const edges = payload.edges
    .map((e) => ({
      source: nodeBySlug.get(e.source),
      target: nodeBySlug.get(e.target),
      particleT: Math.random(),
    }))
    .filter((e) => e.source && e.target);

  // adjacency for neighbor lookup
  const adj = new Map();
  for (const n of nodes) adj.set(n, new Set());
  for (const e of edges) {
    adj.get(e.source).add(e.target);
    adj.get(e.target).add(e.source);
  }

  let width = 0;
  let height = 0;
  let dpr = Math.min(window.devicePixelRatio || 1, 2);

  function resize() {
    const rect = canvas.getBoundingClientRect();
    width = rect.width;
    height = rect.height;
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.floor(width * dpr);
    canvas.height = Math.floor(height * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resize();
  window.addEventListener('resize', resize);

  // --- force simulation (Fruchterman-Reingold-ish, dependency-free) ---
  const LINK_DIST = 110;
  const LINK_STRENGTH = 0.04;
  const CHARGE = 1400;
  const CENTER = 0.015;
  const DAMPING = 0.82;

  function step() {
    const cx = 0;
    const cy = 0;

    // Repulsion (O(n^2), fine for < ~300 nodes).
    for (let i = 0; i < nodes.length; i++) {
      const a = nodes[i];
      for (let j = i + 1; j < nodes.length; j++) {
        const b = nodes[j];
        let dx = a.x - b.x;
        let dy = a.y - b.y;
        let dist2 = dx * dx + dy * dy;
        if (dist2 < 0.01) {
          dx = Math.random() - 0.5;
          dy = Math.random() - 0.5;
          dist2 = dx * dx + dy * dy + 0.01;
        }
        const dist = Math.sqrt(dist2);
        const force = CHARGE / dist2;
        const fx = (dx / dist) * force;
        const fy = (dy / dist) * force;
        a.vx += fx;
        a.vy += fy;
        b.vx -= fx;
        b.vy -= fy;
      }
    }

    // Link attraction.
    for (const e of edges) {
      const dx = e.target.x - e.source.x;
      const dy = e.target.y - e.source.y;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      const delta = (dist - LINK_DIST) * LINK_STRENGTH;
      const fx = (dx / dist) * delta;
      const fy = (dy / dist) * delta;
      e.source.vx += fx;
      e.source.vy += fy;
      e.target.vx -= fx;
      e.target.vy -= fy;
    }

    // Centering + integrate.
    for (const n of nodes) {
      n.vx += (cx - n.x) * CENTER;
      n.vy += (cy - n.y) * CENTER;
      n.vx *= DAMPING;
      n.vy *= DAMPING;
      if (n !== dragging) {
        n.x += n.vx;
        n.y += n.vy;
      }
    }
  }

  // --- camera (animated pan/zoom) ---
  let tx = 0;
  let ty = 0;
  let scale = 1;
  let camTargetX = 0;
  let camTargetY = 0;
  const CAM_LERP = 0.18;

  function worldToScreen(x, y) {
    return { x: (x + tx) * scale + width / 2, y: (y + ty) * scale + height / 2 };
  }
  function screenToWorld(sx, sy) {
    return {
      x: (sx - width / 2) / scale - tx,
      y: (sy - height / 2) / scale - ty,
    };
  }
  function panToWorld(x, y) {
    camTargetX = -x;
    camTargetY = -y;
  }

  // --- focus state ---
  let focused = null;
  let focusedNeighbors = [];
  let focusT = 0; // 0 unfocused -> 1 fully focused
  let releasing = false;
  const FOCUS_LERP = 0.22;

  function neighborsOf(node) {
    const set = adj.get(node) || new Set();
    return [...set]
      .sort((a, b) => b.degree - a.degree)
      .slice(0, NEIGHBOR_MAX);
  }

  function startFocus(node) {
    if (focused === node && !releasing) return;
    focused = node;
    releasing = false;
    focusedNeighbors = neighborsOf(node);
    panToWorld(node.x, node.y);
    renderFocusLabels();
  }

  function releaseFocus() {
    if (!focused) return;
    releasing = true;
  }

  // --- summon (press-and-hold card) ---
  let summoned = null;

  function showSummon(node) {
    summoned = node;
    summonTitleEl.textContent = node.title;
    summonDescEl.textContent = node.description || ' ';
    summonNeighborsEl.replaceChildren();
    const ns = [...(adj.get(node) || [])].slice(0, 12);
    for (const n of ns) {
      const dot = document.createElement('span');
      dot.className = 'summon-neighbor';
      dot.style.background = COLORS[n.collection] || TEXT_DIM;
      summonNeighborsEl.appendChild(dot);
    }
    summonCard.classList.add('is-visible');
    positionSummon();
  }

  function hideSummon() {
    summoned = null;
    summonCard.classList.remove('is-visible');
  }

  function positionSummon() {
    if (!summoned) return;
    const screen = worldToScreen(summoned.x, summoned.y);
    summonCard.style.left = `${screen.x}px`;
    summonCard.style.top = `${screen.y - summoned.r * scale - 14}px`;
  }

  // --- focus labels (DOM overlays, anchored to actual node positions) ---
  function renderFocusLabels() {
    focusLabelsEl.replaceChildren();
    if (!focused) return;
    const centerEl = document.createElement('div');
    centerEl.className = 'focus-label is-center';
    centerEl.textContent = focused.title;
    centerEl.dataset.role = 'center';
    focusLabelsEl.appendChild(centerEl);
    for (let i = 0; i < focusedNeighbors.length; i++) {
      const n = focusedNeighbors[i];
      const el = document.createElement('div');
      el.className = 'focus-label';
      el.textContent = n.title;
      el.dataset.role = 'neighbor';
      el.dataset.index = String(i);
      focusLabelsEl.appendChild(el);
    }
  }

  function positionFocusLabels() {
    if (!focused) return;
    for (const el of focusLabelsEl.children) {
      if (el.dataset.role === 'center') {
        const s = worldToScreen(focused.x, focused.y);
        el.style.left = `${s.x}px`;
        el.style.top = `${s.y + focused.r * scale + 8}px`;
        el.style.opacity = String(focusT);
      } else {
        const idx = Number(el.dataset.index);
        const n = focusedNeighbors[idx];
        if (!n) continue;
        // direction from focused center outward to this neighbor
        const dx = n.x - focused.x;
        const dy = n.y - focused.y;
        const dist = Math.sqrt(dx * dx + dy * dy) || 1;
        const ax = dx / dist;
        const ay = dy / dist;
        const s = worldToScreen(n.x, n.y);
        const pad = n.r * scale + 10;
        const outX = s.x + ax * pad;
        const outY = s.y + ay * pad;
        let tX, tY;
        if (Math.abs(ax) > Math.abs(ay)) {
          tX = ax > 0 ? '0%' : '-100%';
          tY = '-50%';
        } else {
          tX = '-50%';
          tY = ay > 0 ? '0%' : '-100%';
        }
        el.style.left = `${outX}px`;
        el.style.top = `${outY}px`;
        el.style.transform = `translate(${tX}, ${tY})`;
        el.style.opacity = String(Math.max(0, focusT * 1.4 - 0.4));
      }
    }
  }

  // --- hit testing ---
  function nodeAt(sx, sy) {
    const w = screenToWorld(sx, sy);
    for (let i = nodes.length - 1; i >= 0; i--) {
      const n = nodes[i];
      const dx = n.x - w.x;
      const dy = n.y - w.y;
      const r = n.r + 6 / scale;
      if (dx * dx + dy * dy <= r * r) return n;
    }
    return null;
  }

  // --- pointer / gesture handling ---
  let dragging = null;
  let dragMoved = false;
  let panning = false;
  let panStart = { x: 0, y: 0 };
  let panOrigin = { x: 0, y: 0 };
  let pointerDown = null; // { sx, sy, time, type, node }
  let summonTimer = null;
  let hoveredNode = null;

  function localCoords(ev) {
    const rect = canvas.getBoundingClientRect();
    return { sx: ev.clientX - rect.left, sy: ev.clientY - rect.top };
  }

  function clearSummonTimer() {
    if (summonTimer !== null) {
      clearTimeout(summonTimer);
      summonTimer = null;
    }
  }

  function onPointerDown(ev) {
    if (ev.button !== undefined && ev.button !== 0) return;
    canvas.setPointerCapture(ev.pointerId);
    const { sx, sy } = localCoords(ev);
    const n = nodeAt(sx, sy);
    pointerDown = {
      sx,
      sy,
      time: performance.now(),
      type: ev.pointerType,
      node: n,
    };
    dragMoved = false;
    panStart = { x: sx, y: sy };
    panOrigin = { x: tx, y: ty };
    if (n) {
      summonTimer = setTimeout(() => {
        if (pointerDown && pointerDown.node === n && !dragMoved) {
          showSummon(n);
        }
        summonTimer = null;
      }, LONG_PRESS_MS);
    }
  }

  function onPointerMove(ev) {
    const { sx, sy } = localCoords(ev);

    if (pointerDown && !dragMoved) {
      const dx = sx - pointerDown.sx;
      const dy = sy - pointerDown.sy;
      if (dx * dx + dy * dy > MOVE_THRESHOLD * MOVE_THRESHOLD) {
        dragMoved = true;
        clearSummonTimer();
        if (summoned) hideSummon();
        if (pointerDown.node) {
          dragging = pointerDown.node;
          canvas.style.cursor = 'grabbing';
        } else {
          panning = true;
          canvas.style.cursor = 'grabbing';
        }
      }
    }

    if (summoned) {
      positionSummon();
      return;
    }

    if (dragging) {
      const w = screenToWorld(sx, sy);
      dragging.x = w.x;
      dragging.y = w.y;
      dragging.vx = 0;
      dragging.vy = 0;
      return;
    }
    if (panning) {
      tx = panOrigin.x + (sx - panStart.x) / scale;
      ty = panOrigin.y + (sy - panStart.y) / scale;
      camTargetX = tx;
      camTargetY = ty;
      return;
    }

    if (ev.pointerType === 'mouse') {
      const n = nodeAt(sx, sy);
      hoveredNode = n;
      canvas.style.cursor = n ? 'pointer' : 'grab';
      if (n) {
        const screen = worldToScreen(n.x, n.y);
        hoverLabel.textContent = n.title;
        hoverLabel.style.left = `${screen.x}px`;
        hoverLabel.style.top = `${screen.y - n.r * scale - 10}px`;
        hoverLabel.classList.add('is-visible');
      } else {
        hoverLabel.classList.remove('is-visible');
      }
    }
  }

  function onPointerUp(ev) {
    clearSummonTimer();
    const { sx, sy } = localCoords(ev);
    const liftNode = nodeAt(sx, sy);
    const wasSummoned = summoned;
    const wasDragMoved = dragMoved;
    const downNode = pointerDown ? pointerDown.node : null;

    if (wasSummoned) {
      // lift on the summoned node = enter; lift off = dismiss
      if (liftNode === wasSummoned) {
        window.location.href = wasSummoned.url;
      }
      hideSummon();
    } else if (!wasDragMoved && !panning) {
      handleTap(sx, sy, downNode);
    }

    dragging = null;
    panning = false;
    pointerDown = null;
    canvas.style.cursor = hoveredNode ? 'pointer' : 'grab';
  }

  function handleTap(sx, sy, downNode) {
    const tapped = downNode || nodeAt(sx, sy);
    if (focused) {
      if (tapped === focused) {
        // tap the focused node to enter
        window.location.href = focused.url;
      } else if (tapped) {
        // tap any other node (neighbor or background) to re-focus on it
        startFocus(tapped);
      } else {
        // tap empty space to release focus
        releaseFocus();
      }
      return;
    }
    if (tapped) startFocus(tapped);
  }

  canvas.addEventListener('pointerdown', onPointerDown);
  canvas.addEventListener('pointermove', onPointerMove);
  canvas.addEventListener('pointerup', onPointerUp);
  canvas.addEventListener('pointercancel', () => {
    clearSummonTimer();
    if (summoned) hideSummon();
    dragging = null;
    panning = false;
    pointerDown = null;
  });

  canvas.addEventListener(
    'wheel',
    (ev) => {
      ev.preventDefault();
      const { sx, sy } = localCoords(ev);
      const before = screenToWorld(sx, sy);
      const factor = Math.exp(-ev.deltaY * 0.001);
      scale = Math.max(0.25, Math.min(3, scale * factor));
      const after = screenToWorld(sx, sy);
      tx += after.x - before.x;
      ty += after.y - before.y;
      camTargetX = tx;
      camTargetY = ty;
    },
    { passive: false },
  );

  // keyboard: enter on focused canvas enters hovered node, escape releases focus
  canvas.tabIndex = 0;
  canvas.addEventListener('keydown', (ev) => {
    if (ev.key === 'Enter' && hoveredNode) {
      window.location.href = hoveredNode.url;
    } else if (ev.key === 'Escape' && focused) {
      releaseFocus();
    }
  });

  // --- per-frame time-based motion ---
  function advance(dt) {
    if (!reducedMotion) {
      for (const n of nodes) {
        const b = BREATH[n.state] || BREATH.stable;
        n.breathPhase += b.rate * dt;
      }
      for (const e of edges) {
        const dx = e.target.x - e.source.x;
        const dy = e.target.y - e.source.y;
        const dist = Math.sqrt(dx * dx + dy * dy) || 1;
        e.particleT = (e.particleT + (PARTICLE_SPEED * dt) / dist) % 1;
      }
    }
    const target = focused && !releasing ? 1 : 0;
    if (reducedMotion) {
      focusT = target;
    } else {
      focusT += (target - focusT) * FOCUS_LERP;
      if (Math.abs(focusT - target) < 0.001) focusT = target;
    }
    if (releasing && focusT <= 0.005) {
      focused = null;
      focusedNeighbors = [];
      releasing = false;
      focusLabelsEl.replaceChildren();
    }
    if (reducedMotion) {
      tx = camTargetX;
      ty = camTargetY;
    } else {
      tx += (camTargetX - tx) * CAM_LERP;
      ty += (camTargetY - ty) * CAM_LERP;
    }
  }

  function draw() {
    ctx.clearRect(0, 0, width, height);

    ctx.save();
    ctx.translate(width / 2, height / 2);
    ctx.scale(scale, scale);
    ctx.translate(tx, ty);

    const dim = focusT > 0;
    const neighborSet = new Set(focusedNeighbors);

    // edges
    ctx.lineWidth = 1 / scale;
    for (const e of edges) {
      const inFocus =
        focused &&
        ((e.source === focused && neighborSet.has(e.target)) ||
          (e.target === focused && neighborSet.has(e.source)));
      if (inFocus) {
        ctx.strokeStyle = EDGE_FOCUS;
      } else if (dim) {
        const a = 0.35 - 0.27 * focusT;
        ctx.strokeStyle = `rgba(158, 142, 114, ${a})`;
      } else {
        ctx.strokeStyle = EDGE;
      }
      ctx.beginPath();
      ctx.moveTo(e.source.x, e.source.y);
      ctx.lineTo(e.target.x, e.target.y);
      ctx.stroke();
    }

    // edge particles
    if (!reducedMotion) {
      for (const e of edges) {
        const px = e.source.x + (e.target.x - e.source.x) * e.particleT;
        const py = e.source.y + (e.target.y - e.source.y) * e.particleT;
        const inFocus =
          focused &&
          ((e.source === focused && neighborSet.has(e.target)) ||
            (e.target === focused && neighborSet.has(e.source)));
        const baseAlpha = inFocus ? 0.9 : dim ? 0.2 : 0.55;
        ctx.globalAlpha = baseAlpha;
        ctx.fillStyle = COLORS[e.source.collection] || TEXT_DIM;
        ctx.beginPath();
        ctx.arc(px, py, 1.6 / scale, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    }

    // nodes
    for (const n of nodes) {
      const isFocused = n === focused;
      const isNeighbor = neighborSet.has(n);
      let alpha = n.state === 'fossil' ? 0.55 : 1;
      if (dim && !isFocused && !isNeighbor) {
        alpha *= 1 - 0.7 * focusT;
      }
      ctx.globalAlpha = alpha;
      ctx.fillStyle = COLORS[n.collection] || TEXT_DIM;
      const b = BREATH[n.state] || BREATH.stable;
      const breath = reducedMotion ? 0 : b.amp * Math.sin(n.breathPhase);
      let r = n.r * (1 + breath);
      if (isFocused) r *= 1 + 0.18 * focusT;
      ctx.beginPath();
      ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;

    // neighbor rings (subtle outline so neighbors read as "in-focus" not just "bright")
    if (focused && focusT > 0.1) {
      ctx.strokeStyle = `rgba(240, 230, 210, ${0.5 * focusT})`;
      ctx.lineWidth = 1 / scale;
      for (const n of focusedNeighbors) {
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r + 2 / scale, 0, Math.PI * 2);
        ctx.stroke();
      }
    }

    // hover ring (desktop only, not while focused)
    if (hoveredNode && !focused) {
      ctx.strokeStyle = HIGHLIGHT;
      ctx.lineWidth = 2 / scale;
      ctx.beginPath();
      ctx.arc(hoveredNode.x, hoveredNode.y, hoveredNode.r + 3 / scale, 0, Math.PI * 2);
      ctx.stroke();
    }

    // focused-center highlight ring
    if (focused && focusT > 0.1) {
      ctx.strokeStyle = HIGHLIGHT;
      ctx.lineWidth = 2 / scale;
      ctx.globalAlpha = focusT;
      ctx.beginPath();
      ctx.arc(
        focused.x,
        focused.y,
        focused.r * (1 + 0.18 * focusT) + 4 / scale,
        0,
        Math.PI * 2,
      );
      ctx.stroke();
      ctx.globalAlpha = 1;
    }

    ctx.restore();

    positionFocusLabels();
    if (summoned) positionSummon();
  }

  // settle for a few hundred frames without drawing so first paint isn't chaos
  for (let i = 0; i < 240; i++) step();

  let lastTime = performance.now();
  function tick(now) {
    const dt = Math.min(0.05, (now - lastTime) / 1000);
    lastTime = now;
    step();
    advance(dt);
    draw();
    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
</script>

<style>
  .rhizome {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }
  header {
    margin-bottom: 1.5rem;
  }
  header h1 {
    font-family: 'EB Garamond', Georgia, serif;
    font-weight: 500;
    font-size: 2.2rem;
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
  }
  .sub {
    color: var(--text-dim);
    font-style: italic;
    margin: 0 0 1rem;
  }
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-jetbrains);
    font-size: 0.72rem;
    color: var(--text-dim);
    text-transform: lowercase;
    letter-spacing: 0.08em;
  }
  .legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .dot {
    display: inline-block;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
  }
  .dot.essays {
    background: #e8a838;
