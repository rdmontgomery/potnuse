---
import { getEntry, render } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Backlinks from '@/components/Backlinks.astro';
import StateBadge from '@/components/StateBadge.astro';
import InvisibleInk from '@/components/invisible-ink/App';

const entry = await getEntry('experiments', 'invisible-ink');
if (!entry) throw new Error('invisible-ink entry not found');
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={entry.data.description}>
  <article class="essay">
    <header>
      <h1>{entry.data.title}</h1>
      <div class="meta">
        <StateBadge state={entry.data.state} />
        {
          entry.data.date && (
            <time datetime={entry.data.date.toISOString()}>
              {entry.data.date.toISOString().slice(0, 10)}
            </time>
          )
        }
      </div>
    </header>

    <InvisibleInk client:only="react" />

    <div class="prose">
      <Content />
    </div>

    <Backlinks slug="invisible-ink" />
  </article>
</Base>

<style>
  .essay {
    max-width: 680px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }
  header h1 {
    font-family: var(--font-crimson);
    font-size: 2.6rem;
    font-weight: 500;
    margin: 0 0 0.75rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .meta {
    display: flex;
    gap: 0.8rem;
    align-items: center;
    color: var(--text-dim);
    font-family: var(--font-jetbrains);
    font-size: 0.75rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .prose :global(p) {
    margin: 1.2em 0;
  }
  .prose :global(a) {
    color: var(--text);
    border-bottom: 1px solid rgba(232, 168, 56, 0.5);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .prose :global(a:hover) {
    color: var(--accent);
  }
  .prose :global(h2) {
    font-family: var(--font-crimson);
    font-size: 1.45rem;
    margin: 2.5em 0 0.5em;
    font-weight: 500;
  }
  .prose :global(code) {
    font-family: var(--font-jetbrains);
    font-size: 0.88em;
    background: var(--bg-card);
    padding: 0.08em 0.35em;
    border-radius: 3px;
  }
  .prose :global(blockquote) {
    border-left: 2px solid var(--border);
    margin: 1.5em 0;
    padding: 0 0 0 1.2em;
    color: var(--text-dim);
    font-style: italic;
  }
</style>
