---
import Base from '@/layouts/Base.astro';
import Ladder from '@/components/ladder/App';
import Backlinks from '@/components/Backlinks.astro';
---

<Base
  title="ladder"
  description="A spaced-repetition climb up the staff. Treble, bass, or grand — notes you miss return sooner; notes you know drift further back."
>
  <Ladder client:only="react" />
  <section class="chrome">
    <Backlinks slug="ladder" />
  </section>
</Base>

<style>
  .chrome {
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }
</style>
